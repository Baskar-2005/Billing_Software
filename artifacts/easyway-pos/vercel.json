{
  "version": 2,
  "installCommand": "npm install -g pnpm@10 && cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/easyway-pos run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
