{
  "version": 2,
  "installCommand": "npm install -g pnpm@10 && cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm run typecheck:libs",
  "framework": null,
  "functions": {
    "src/vercel.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/src/vercel.ts" }
  ]
}
